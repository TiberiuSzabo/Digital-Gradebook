{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=gradebook.db"
  },
  "MongoDbSettings": {
    "ConnectionString": "SET_VIA_ENV_VAR__MONGODBSETTINGS__CONNECTIONSTRING",
    "DatabaseName": "GradebookChat"
  },
  "JwtSettings": {
    "Secret": "SET_VIA_ENV_VAR__JWTSETTINGS__SECRET",
    "Issuer": "DigitalGradebookAPI",
    "Audience": "DigitalGradebookClient",
    "ExpirationMinutes": 30
  },
  "EmailSettings": {
    "BrevoApiKey": "SET_VIA_ENV_VAR__EMAILSETTINGS__BREVIOAPIKEY",
    "SenderEmail": "szaborobert2005@gmail.com",
    "SenderName": "Digital Gradebook"
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "http://localhost:3000"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}